# Copy to .env and fill in values:
#   cp .env.example .env

# Public IP of this machine (used in --endpoint)
INSTANCE_IP=YOUR.PUBLIC.IP

# Public HTTPS port nginx listens on (host must forward this port here)
EXTERNAL_PORT=40019

# Bittensor wallet already present under ~/.bittensor/wallets/
COLDKEY_NAME=mywallet
HOTKEY_NAME=default

# Hugging Face token (read-only access is enough for public models)
HUGGING_FACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# VERATHOS_DIR=/root/verathos
# VERATHOS_REPO=https://github.com/verathos-ai/verathos
# MODEL_ID=auto
# Or pin a concrete HF checkpoint (skips GPU auto-select):
# MODEL_ID=cyankiwi/Qwen3.6-27B-AWQ-INT4
# NETUID=96
# NETWORK=finney
# LOCAL_PORT=8000
# GPU_ID=0
# PM2_NAME=verathos-gpu0
# GPU_MEMORY_UTILIZATION=0.85
